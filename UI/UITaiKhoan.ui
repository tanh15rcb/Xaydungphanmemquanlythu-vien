         <item><property name="text"><string>Nhân viên</string></property></item>
        </widget>
       </item>

       <item row="3" column="0">
        <widget class="QLabel">
         <property name="text"><string>Trạng thái:</string></property>
        </widget>
       </item>

       <item row="3" column="1">
        <widget class="QComboBox" name="cb_status">
         <item><property name="text"><string>Hoạt động</string></property></item>
         <item><property name="text"><string>Khóa</string></property></item>
        </widget>
       </item>

      </layout>
     </widget>
    </item>

    <!-- BUTTONS -->
    <item>
     <layout class="QHBoxLayout">

      <item>
       <widget class="QPushButton" name="btn_add">
        <property name="text"><string>Thêm</string></property>
        <property name="styleSheet">
         <string>background:#2ecc71; color:white;</string>
        </property>
       </widget>
      </item>

      <item>
       <widget class="QPushButton" name="btn_update">
        <property name="text"><string>Sửa</string></property>
        <property name="styleSheet">
