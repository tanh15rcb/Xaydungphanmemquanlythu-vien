      </property>
      <property name="styleSheet">
       <string>font-size:22px; font-weight:bold;</string>
      </property>
     </widget>
    </item>

    <!-- FORM -->
    <item>
     <widget class="QFrame">
      <property name="styleSheet">
       <string>
        background:white;
        border-radius:10px;
        border:1px solid #ccc;
       </string>
      </property>

      <layout class="QGridLayout">

       <item row="0" column="0">
        <widget class="QLabel">
         <property name="text"><string>Tên đăng nhập:</string></property>
        </widget>
