    <width>1100</width>
    <height>650</height>
   </rect>
  </property>

  <property name="windowTitle">
   <string>Quản lý tài khoản</string>
  </property>

  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout">

    <!-- TITLE -->
    <item>
     <widget class="QLabel">
      <property name="text">
